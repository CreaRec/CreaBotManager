# Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN=

# Comma-separated list of Telegram numeric user IDs allowed to use the bot.
# Find yours by messaging @userinfobot. Leave empty to (DANGEROUSLY) allow everyone.
ALLOWED_TELEGRAM_IDS=

# Max time (ms) for processing one Telegram update before Telegraf times out. Default 180000 (3 min).
BOT_HANDLER_TIMEOUT_MS=180000

# Optional: server SSH/sudo password for scripts/deploy.sh (local dev machine only).
# Requires sshpass locally. When unset, deploy prompts for passwords interactively.
# DEPLOY_PASSWORD=
