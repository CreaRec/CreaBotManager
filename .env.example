# Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN=

# Your Telegram user ID as the single admin (get it from @userinfobot).
# Only this person can add/remove bots and manage other users.
# Everyone else is added via /useradd and /usergrant in Telegram.
ADMIN_TELEGRAM_IDS=

# Max time (ms) for processing one Telegram update before Telegraf times out. Default 180000 (3 min).
BOT_HANDLER_TIMEOUT_MS=180000

# Runtime data (not overwritten by deploy). Migrated automatically from config/ on first start.
MANAGED_BOTS_CONFIG=data/managed-bots.json
USER_PERMISSIONS_CONFIG=data/user-permissions.json

# Docker CLI path (defaults usually fine inside the container and on the host).
DOCKER_PATH=/usr/bin/docker

# Optional: Docker host (defaults to unix:///var/run/docker.sock when unset).
# DOCKER_HOST=unix:///var/run/docker.sock

# Production compose (server .env) — required on the host deploy directory:
# IMAGE=ghcr.io/crearec/crea-bot-manager
# IMAGE_TAG=main
#
# Numeric GID of the host docker group / socket owner (required for group_add).
# Compose does NOT expand shell: put the number, not $(stat ...).
#   Linux:  stat -c '%g' /var/run/docker.sock
#   macOS:  stat -f '%g' /var/run/docker.sock
# DOCKER_GID=998
