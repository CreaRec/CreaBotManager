# Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN=

# Comma-separated admin Telegram user IDs (full access + user/bot registry management).
# Find yours via @userinfobot. Required for production.
ADMIN_TELEGRAM_IDS=

# Deprecated alias for ADMIN_TELEGRAM_IDS (used only when ADMIN_TELEGRAM_IDS is empty).
ALLOWED_TELEGRAM_IDS=

# Max time (ms) for processing one Telegram update before Telegraf times out. Default 180000 (3 min).
BOT_HANDLER_TIMEOUT_MS=180000

# Path to JSON registry of managed bot services (relative to app dir or absolute).
MANAGED_BOTS_CONFIG=config/managed-bots.json

# Path to per-user bot access permissions (managed via /useradd, /usergrant in Telegram).
USER_PERMISSIONS_CONFIG=config/user-permissions.json

# systemd/journalctl paths on Debian (defaults usually fine).
SYSTEMCTL_PATH=/bin/systemctl
JOURNALCTL_PATH=/bin/journalctl

# Run systemctl/journalctl via passwordless sudo (see deploy/sudoers-crea-bot-manager.example).
USE_SUDO_FOR_SYSTEMCTL=true

# Optional: server SSH/sudo password for scripts/deploy.sh (local dev machine only).
# Requires sshpass locally. When unset, deploy prompts for passwords interactively.
# DEPLOY_PASSWORD=
